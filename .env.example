# OpenManus Environment Configuration Template
# Copy this file to .env and modify the values as needed

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./openmanus.db

# JWT Secret Key (MUST change this in production!)
SECRET_KEY=your-super-secret-jwt-key-change-in-production-please

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000"]

# Logging Configuration
LOG_LEVEL=INFO

# Agent Configuration
AGENT_TIMEOUT=300
AGENT_MAX_STEPS=50

# Event System Configuration
EVENT_PERSISTENCE_ENABLED=true
EVENT_TRACKING_ENABLED=true

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Optional: External API Keys
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: Production Database
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/openmanus

# Security Settings
BCRYPT_ROUNDS=12
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Development Settings
RELOAD_ON_CHANGE=false
ENABLE_DOCS=true
